#!/usr/bin/env python3
"""Open the NoMachine client (action: nomachine.connect)."""
from __future__ import annotations

import os
import shutil
import subprocess
import sys

NX_PORT = 4000


def find_client() -> str | None:
    import platform
    if platform.system() == "Darwin":
        mac = "/Applications/NoMachine.app/Contents/MacOS/nxplayer"
        if os.access(mac, os.X_OK):
            return mac
    for c in ("nxplayer", "/usr/NX/bin/nxplayer"):
        if shutil.which(c) or os.access(c, os.X_OK):
            return c
    return None


def main() -> int:
    ip = os.environ.get("EVE_REMOTE_IP", "")
    if not ip:
        print("nomachine-connect: EVE_REMOTE_IP is not set", file=sys.stderr)
        return 1
    client = find_client()
    if not client:
        print("NoMachine client (nxplayer) not found locally", file=sys.stderr)
        return 1
    print(f"Opening NoMachine to {ip}:{NX_PORT}...")
    subprocess.Popen([client, f"nx://{ip}:{NX_PORT}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
