#!/usr/bin/env python3
"""Print or open the RustDesk connection (actions: rustdesk.connect / rustdesk.info).

Reads the EVE_REMOTE_* context and uses $EVE_REMOTE_ROOT/scripts/instance-ssh for
the remote state queries. Behavior ported verbatim from core scripts/remote-rustdesk.
"""
from __future__ import annotations

import os
import re
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _client import rustdesk_connect_command, rustdesk_local_client, shell_quote  # noqa: E402

_USAGE = (
    "Prints the RustDesk connection details for the instance.\n"
    "With 'connect', configures the local RustDesk client and opens a connection.\n"
)

# Windows remote command fragments (PowerShell)
_RD_LOCATE = (
    '$rd = @("C:\\Program Files\\RustDesk\\rustdesk.exe",'
    '"C:\\Program Files (x86)\\RustDesk\\rustdesk.exe",'
    '"C:\\Users\\Administrator\\AppData\\Local\\rustdesk\\rustdesk.exe",'
    '"C:\\Windows\\System32\\config\\systemprofile\\AppData\\Local\\rustdesk\\rustdesk.exe",'
    '"$env:LOCALAPPDATA\\rustdesk\\rustdesk.exe") '
    "| Where-Object { Test-Path $_ } | Select-Object -First 1; "
    "if (-not $rd) { $proc = Get-Process rustdesk -ErrorAction SilentlyContinue "
    "| Select-Object -First 1; if ($proc -and $proc.Path) { $rd = $proc.Path } }"
)
_CFG_LOCATE = (
    '$cfg = @("C:\\Users\\Administrator\\AppData\\Roaming\\RustDesk\\config\\RustDesk2.toml",'
    '"C:\\Windows\\System32\\config\\systemprofile\\AppData\\Roaming\\RustDesk\\config\\RustDesk2.toml",'
    '"$env:APPDATA\\RustDesk\\config\\RustDesk2.toml") '
    "| Where-Object { Test-Path $_ } | Select-Object -First 1"
)
_LINUX_PREP_PREFIX = "sudo systemctl start rustdesk 2>/dev/null || true; rd_user="
_LINUX_PREP_SUFFIX = (
    '; if id "$rd_user" >/dev/null 2>&1; then uid=$(id -u "$rd_user"); '
    'home=$(getent passwd "$rd_user" | cut -d: -f6); runtime="/run/user/$uid"; '
    'if [ -d "$runtime" ]; then '
    'sudo -H -u "$rd_user" env HOME="$home" USER="$rd_user" LOGNAME="$rd_user" '
    'XDG_RUNTIME_DIR="$runtime" DISPLAY="${DISPLAY:-:0}" '
    'XAUTHORITY="${XAUTHORITY:-$home/.Xauthority}" '
    "systemctl --user import-environment DISPLAY XAUTHORITY XDG_RUNTIME_DIR 2>/dev/null || true; "
    'sudo -H -u "$rd_user" env HOME="$home" USER="$rd_user" LOGNAME="$rd_user" '
    'XDG_RUNTIME_DIR="$runtime" DISPLAY="${DISPLAY:-:0}" '
    'XAUTHORITY="${XAUTHORITY:-$home/.Xauthority}" '
    "setsid rustdesk --server >/tmp/eve-rustdesk-user.log 2>&1 < /dev/null & fi; fi; sleep 2"
)
_LINUX_PREP_NO_USER = (
    "sudo systemctl start rustdesk 2>/dev/null || true; uid=$(id -u); "
    'home=$(getent passwd "$USER" | cut -d: -f6); export XDG_RUNTIME_DIR="/run/user/$uid"; '
    'export DISPLAY="${DISPLAY:-:0}"; export XAUTHORITY="${XAUTHORITY:-$home/.Xauthority}"; '
    'if [ -d "$XDG_RUNTIME_DIR" ]; then '
    "systemctl --user import-environment DISPLAY XAUTHORITY XDG_RUNTIME_DIR 2>/dev/null || true; "
    "setsid rustdesk --server >/tmp/eve-rustdesk-user.log 2>&1 < /dev/null & fi; sleep 2"
)
_LINUX_GET_ID = "sudo rustdesk --get-id 2>/dev/null || rustdesk --get-id 2>/dev/null || true"
_LINUX_SERVER = (
    'sudo grep -E "^(rendezvous_server|custom-rendezvous-server)" '
    '/root/.config/rustdesk/RustDesk2.toml 2>/dev/null | tail -1 | sed "s/^[^=]*= .//;s/.$//"'
)
_LINUX_KEY = (
    'sudo grep "^key " /root/.config/rustdesk/RustDesk2.toml 2>/dev/null | sed "s/^key = .//;s/.$//"'
)


def _ssh(root: str, instance: str, remote_cmd: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        [str(Path(root) / "scripts/instance-ssh"), instance, "--", remote_cmd],
        cwd=root, text=True, capture_output=True, check=False,
    )


def main() -> int:
    action = os.environ.get("EVE_REMOTE_ACTION", "")
    connect = action.endswith(".connect")
    root = os.environ.get("EVE_REMOTE_ROOT", ".")
    instance = os.environ.get("EVE_REMOTE_INSTANCE", "")
    os_family = os.environ.get("EVE_REMOTE_OS_FAMILY", "") or os.environ.get("OS_FAMILY", "")
    vm_user_name = os.environ.get("VM_USER_NAME", "")

    if os_family == "windows":
        prep_cmd = (
            f"{_RD_LOCATE}; if ($rd) {{ $script = "
            "'C:\\Users\\Administrator\\provision\\state\\configure-rustdesk-user.ps1'; "
            "if (Test-Path $script) { powershell.exe -NoProfile -ExecutionPolicy Bypass "
            "-WindowStyle Hidden -File $script | Out-Null }; "
            "$proc = Get-Process rustdesk -ErrorAction SilentlyContinue | Select-Object -First 1; "
            "if (-not $proc) { Start-Process -FilePath $rd -WindowStyle Hidden; "
            "Start-Sleep -Seconds 5 } }"
        )
        get_id_cmd = f"{_RD_LOCATE}; if ($rd) {{ & $rd --get-id }} else {{ Write-Error 'rustdesk.exe not found on remote' }}"
        server_cmd = (
            f"{_CFG_LOCATE}; if ($cfg) {{ Get-Content $cfg | Select-String "
            "-Pattern '^(rendezvous_server|custom-rendezvous-server)' | Select-Object -Last 1 | "
            "ForEach-Object { ($_ -split '=',2)[1].Trim().Trim(\"'\") } }"
        )
        key_cmd = (
            f"{_CFG_LOCATE}; if ($cfg) {{ Get-Content $cfg | Select-String -Pattern '^key ' | "
            "Select-Object -First 1 | ForEach-Object { ($_ -split '=',2)[1].Trim().Trim(\"'\") } }"
        )
    else:
        if vm_user_name:
            prep_cmd = _LINUX_PREP_PREFIX + shell_quote(vm_user_name) + _LINUX_PREP_SUFFIX
        else:
            prep_cmd = _LINUX_PREP_NO_USER
        get_id_cmd = _LINUX_GET_ID
        server_cmd = _LINUX_SERVER
        key_cmd = _LINUX_KEY

    _ssh(root, instance, prep_cmd)  # output + errors ignored
    id_result = _ssh(root, instance, get_id_cmd)
    rustdesk_id = re.sub(r"\s", "", id_result.stdout)
    if not rustdesk_id:
        print("RustDesk ID not available — is the service running?", file=sys.stderr)
        return 1
    server = _ssh(root, instance, server_cmd).stdout.replace("\r", "")
    key = _ssh(root, instance, key_cmd).stdout.replace("\r", "")

    if connect:
        cli = rustdesk_local_client()
        if not cli:
            print("RustDesk client not found locally", file=sys.stderr)
            return 1
        print(f"Connecting to RustDesk ID {rustdesk_id}...")
        subprocess.Popen(
            rustdesk_connect_command(cli, rustdesk_id),
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True,
        )
        return 0

    print(f"RustDesk ID:  {rustdesk_id}")
    print(f"Server:       {server or '(default)'}")
    print(f"Key:          {key or '(not set)'}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
