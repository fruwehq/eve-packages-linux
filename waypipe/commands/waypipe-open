#!/usr/bin/env python3
"""Run a remote Wayland app through waypipe (action: waypipe.open).

Reads EVE_REMOTE_*; APP env gives the app (+args). Uses $EVE_REMOTE_ROOT/scripts/
vagrant-up + instance-paths + `vagrant ssh-config` for the vagrant engine.
Behavior ported from core scripts/remote-waypipe.
"""
from __future__ import annotations

import os
import shlex
import subprocess
import sys
import tempfile
from pathlib import Path

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _client import waypipe_ssh_command, waypipe_ssh_opts, waypipe_vagrant_command  # noqa: E402


def _has_command(name: str) -> bool:
    from shutil import which
    return which(name) is not None


def _exec_replace(cmd: list[str]) -> int:
    os.execvp(cmd[0], cmd)
    return 0  # unreachable


def _ssh_config_field(config: str, field: str) -> str:
    for line in config.splitlines():
        parts = line.split()
        if len(parts) >= 2 and parts[0] == field:
            return parts[1]
    return ""


def _instance_workdir(root: str, instance: str) -> str:
    result = subprocess.run(
        [str(Path(root) / "scripts/instance-paths"), "--instance", instance, "--emit", "env"],
        cwd=root, text=True, capture_output=True, check=False,
    )
    if result.returncode != 0:
        raise SystemExit(result.returncode)
    for line in result.stdout.splitlines():
        if line.startswith("INSTANCE_WORKDIR="):
            return line.split("=", 1)[1]
    raise SystemExit(1)


def _vagrant_ssh_config(workdir: str) -> str:
    result = subprocess.run(["vagrant", "ssh-config"], cwd=workdir, capture_output=True, text=True, check=False)
    if result.returncode != 0:
        raise SystemExit(result.returncode)
    return result.stdout


def main() -> int:
    app = shlex.split(os.environ.get("APP", ""))
    root = os.environ.get("EVE_REMOTE_ROOT", ".")
    instance = os.environ.get("EVE_REMOTE_INSTANCE", "")
    engine = os.environ.get("EVE_REMOTE_ENGINE", "") or os.environ.get("ENGINE", "")
    os_family = os.environ.get("EVE_REMOTE_OS_FAMILY", "") or os.environ.get("OS_FAMILY", "")
    ip = os.environ.get("EVE_REMOTE_IP", "")
    ssh_user = os.environ.get("SSH_USER", "")

    if not _has_command("waypipe"):
        print("waypipe-open: local waypipe is not installed.", file=sys.stderr)
        print("  macOS: brew tap J-x-Z/tap && brew install cocoa-way waypipe-darwin", file=sys.stderr)
        return 2
    if not os.environ.get("WAYLAND_DISPLAY"):
        print("waypipe-open: WAYLAND_DISPLAY is not set on the local machine.", file=sys.stderr)
        print("  Start Cocoa-Way first, then export XDG_RUNTIME_DIR + WAYLAND_DISPLAY.", file=sys.stderr)
        return 2
    if os_family != "ubuntu":
        print("waypipe-open: waypipe is currently implemented for Ubuntu instances only.", file=sys.stderr)
        return 2

    if engine == "vagrant":
        subprocess.run(
            [str(Path(root) / "scripts/vagrant-up"), "--plan", instance],
            cwd=root, stdout=subprocess.DEVNULL, check=False,
        )
        workdir = _instance_workdir(root, instance)
        tmp_config = tempfile.mktemp(prefix="eve-waypipe-ssh.", dir=os.environ.get("TMPDIR", "/tmp"))
        Path(tmp_config).write_text(_vagrant_ssh_config(workdir))
        try:
            _exec_replace(waypipe_vagrant_command(tmp_config, app))
        finally:
            Path(tmp_config).unlink(missing_ok=True)
        return 0

    if not ip:
        print("waypipe-open: EVE_REMOTE_IP is not set", file=sys.stderr)
        return 1
    priv_key = os.environ.get("EVE_REMOTE_KEY", "")
    _exec_replace(waypipe_ssh_command(waypipe_ssh_opts(priv_key), f"{ssh_user}@{ip}", app))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
