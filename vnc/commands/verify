#!/usr/bin/env python3
"""Verify VNC server + XFCE session (action: verify)."""
from __future__ import annotations

import os
import subprocess
import sys

ROOT = os.environ.get("EVE_REMOTE_ROOT", ".")
INST = os.environ.get("EVE_REMOTE_INSTANCE", "")
USER = os.environ.get("VM_USER_NAME", "") or os.environ.get("SSH_USER", "")
failures = 0


def remote_check(cmd: str) -> bool:
    return subprocess.run([f"{ROOT}/scripts/instance-ssh", INST, "--", cmd],
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def q(s: str) -> str:
    return "'" + s.replace("'", "'\\''") + "'"


def main() -> int:
    global failures
    if remote_check('systemctl is-active --quiet vncserver.service && ss -tln | grep -q ":5901 "'):
        print(f"ok   {'vnc':<14} TigerVNC active on tcp/5901")
    else:
        print(f"fail {'vnc':<14} TigerVNC is not active/listening on tcp/5901")
        failures += 1
    if not USER:
        print(f"fail {'vnc':<14} VM_USER_NAME is not known, cannot verify XFCE session")
        return 1
    huq = q(USER)
    if remote_check(
        f'human_user={huq}; pgrep -u "$human_user" -f \'xfce4-session|xfwm4|xfdesktop\' >/dev/null 2>&1'
    ):
        print(f"ok   {'vnc':<14} XFCE session process is running")
    else:
        print(f"fail {'vnc':<14} no XFCE session process found; VNC may show a black screen")
        failures += 1
    return 1 if failures else 0


if __name__ == "__main__":
    raise SystemExit(main())
