#!/usr/bin/env python3
"""Start a Moonlight stream to the instance (action: moonlight.open)."""
from __future__ import annotations

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _client import moonlight_stream_command  # noqa: E402


def main() -> int:
    if "sunshine" not in os.environ.get("BUNDLE_PACKAGES", "").split(","):
        print("sunshine not in bundle — skipping")
        return 0
    ip = os.environ.get("EVE_REMOTE_IP", "")
    if not ip:
        print("moonlight-open: EVE_REMOTE_IP is not set", file=sys.stderr)
        return 1
    cmd = moonlight_stream_command(ip)
    os.execvp(cmd[0], cmd)
    return 0  # unreachable


if __name__ == "__main__":
    raise SystemExit(main())
