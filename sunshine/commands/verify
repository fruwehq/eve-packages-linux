#!/usr/bin/env python3
"""Verify Sunshine API + capture display (action: verify)."""
from __future__ import annotations

import os
import subprocess
import sys

ROOT = os.environ.get("EVE_REMOTE_ROOT", ".")
INST = os.environ.get("EVE_REMOTE_INSTANCE", "")
IP = os.environ.get("EVE_REMOTE_IP", "")
OSF = os.environ.get("EVE_REMOTE_OS_FAMILY", "") or os.environ.get("OS_FAMILY", "")
USER = os.environ.get("VM_USER_NAME", "") or os.environ.get("SSH_USER", "")
PASSWORD = os.environ.get("EPHEMERAL_SUNSHINE_PASSWORD", "")
failures = 0


def remote_check(cmd: str) -> bool:
    return subprocess.run([f"{ROOT}/scripts/instance-ssh", INST, "--", cmd],
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def q(s: str) -> str:
    return "'" + s.replace("'", "'\\''") + "'"


def main() -> int:
    global failures
    # Sunshine API reachability (local curl against the instance IP).
    if IP and PASSWORD:
        probe = subprocess.run(
            ["curl", "-sS", "-k", "-L", "-u", f"sunshine:{PASSWORD}",
             "-o", "/dev/null", "-w", "%{http_code}", f"https://{IP}:47990/api/config"],
            capture_output=True, text=True, check=False,
        )
        if probe.stdout.startswith("2"):
            print(f"ok   {'sunshine':<14} Sunshine API reachable")
        else:
            print(f"fail {'sunshine':<14} Sunshine API is not reachable")
            failures += 1
    else:
        print(f"fail {'sunshine':<14} EVE_REMOTE_IP or EPHEMERAL_SUNSHINE_PASSWORD not set")
        failures += 1

    if OSF == "ubuntu":
        if not USER:
            print(f"fail {'sunshine':<14} VM_USER_NAME is not known, cannot verify X display")
            failures += 1
            return 1 if failures else 0
        huq = q(USER)
        if remote_check(
            f'human_user={huq}; uid=$(id -u "$human_user"); home=$(getent passwd "$human_user" | cut -d: -f6); '
            r'sudo -H -u "$human_user" env HOME="$home" USER="$human_user" LOGNAME="$human_user" '
            r'XDG_RUNTIME_DIR="/run/user/$uid" DISPLAY="${SUNSHINE_DISPLAY:-:0}" '
            r'XAUTHORITY="${XAUTHORITY:-$home/.Xauthority}" xrandr --query >/dev/null 2>&1'
        ):
            print(f"ok   {'sunshine':<14} X display is available for capture")
        else:
            print(f"fail {'sunshine':<14} no usable X display for capture")
            failures += 1
    elif OSF == "windows":
        if remote_check(
            r'''powershell.exe -NoProfile -Command '$marker = "C:\Users\Administrator\provision\state\display-config-done.flag"; if (-not (Test-Path -LiteralPath $marker)) { exit 1 }; $content = (Get-Content -LiteralPath $marker -Raw).Trim(); if ($content -notmatch "^OK\b") { exit 1 }' '''
        ):
            print(f"ok   {'sunshine':<14} Windows VDD display setup completed")
        else:
            print(f"fail {'sunshine':<14} Windows VDD display setup failed")
            failures += 1
    return 1 if failures else 0


if __name__ == "__main__":
    raise SystemExit(main())
