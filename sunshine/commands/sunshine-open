#!/usr/bin/env python3
"""Open the Sunshine web UI (action: sunshine.open)."""
from __future__ import annotations

import os
import shutil
import subprocess
import sys


def main() -> int:
    ip = os.environ.get("EVE_REMOTE_IP", "")
    if not ip:
        print("sunshine-open: EVE_REMOTE_IP is not set", file=sys.stderr)
        return 1
    opener = "open" if shutil.which("open") else "xdg-open"
    return subprocess.run([opener, f"https://{ip}:47990"], check=False).returncode


if __name__ == "__main__":
    raise SystemExit(main())
