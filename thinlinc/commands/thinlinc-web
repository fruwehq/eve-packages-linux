#!/usr/bin/env python3
"""Open the ThinLinc Web Access page (action: thinlinc.web)."""
from __future__ import annotations

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _client import has_command, thinlinc_url, url_open_command  # noqa: E402


def main() -> int:
    ip = os.environ.get("EVE_REMOTE_IP", "")
    if not ip:
        print("thinlinc-web: EVE_REMOTE_IP is not set", file=sys.stderr)
        return 1
    opener = "open" if has_command("open") else "xdg-open"
    cmd = url_open_command(opener, thinlinc_url(ip))
    os.execvp(cmd[0], cmd)
    return 0  # unreachable


if __name__ == "__main__":
    raise SystemExit(main())
