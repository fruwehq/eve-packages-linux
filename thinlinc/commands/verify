#!/usr/bin/env python3
"""Verify ThinLinc services + Web Access (action: verify)."""
from __future__ import annotations

import os
import subprocess
import sys

ROOT = os.environ.get("EVE_REMOTE_ROOT", ".")
INST = os.environ.get("EVE_REMOTE_INSTANCE", "")
failures = 0


def remote_check(cmd: str) -> bool:
    return subprocess.run([f"{ROOT}/scripts/instance-ssh", INST, "--", cmd],
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def main() -> int:
    global failures
    if remote_check(
        'systemctl is-active --quiet vsmserver.service && '
        'systemctl is-active --quiet vsmagent.service && '
        'systemctl is-active --quiet tlwebaccess.service'
    ):
        print(f"ok   {'thinlinc':<14} ThinLinc services are active")
    else:
        print(f"fail {'thinlinc':<14} one or more ThinLinc services are not active")
        failures += 1
    port = os.environ.get("THINLINC_WEBACCESS_PORT", "300")
    if remote_check(f'ss -tln | grep -Eq ":(300|{port}) "'):
        print(f"ok   {'thinlinc':<14} Web Access is listening")
    else:
        print(f"fail {'thinlinc':<14} ThinLinc Web Access is not listening")
        failures += 1
    return 1 if failures else 0


if __name__ == "__main__":
    raise SystemExit(main())
